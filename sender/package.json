{
  "name": "m5stickc-plus-monitor-sender",
  "version": "0.1.0",
  "private": true,
  "description": "Node sender for M5StickC Plus PC monitor over USB serial or BLE.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "list-ports": "node src/index.js --list-ports",
    "list-ble": "node src/index.js --list-ble"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-25",
    "commander": "^12.0.0",
    "serialport": "^12.0.0",
    "systeminformation": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@abandonware/bluetooth-hci-socket",
      "@abandonware/noble",
